      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "🟡 Soft Brake",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"soft_brake\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": -0.8 },
            { "color": "yellow", "value": -0.5 },
            { "color": "light-yellow", "value": -0.3 },
            { "color": "green", "value": 0 }
          ]},
          "decimals": 2,
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "id": 20,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "📐 ADX MEI（動能耗盡）",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"adx_mei\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "📈 Market Regime — 趨勢圖",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percentunit",
          "min": 0, "max": 1,
          "displayName": "Composite Score",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "blue", "value": 0.40 },
              { "color": "orange", "value": 0.55 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 23 },
      "id": 11,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "title": "📊 Composite Score 趨勢",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"market_score\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "yellow", "mode": "fixed" },
