  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["algo", "trading", "live"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "🤖 Algo Trading Monitor",
  "uid": "algo-trading-v3",
  "version": 1
}
