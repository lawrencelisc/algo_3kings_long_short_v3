            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "blue", "value": 20 },
              { "color": "orange", "value": 25 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 30 },
      "id": 12,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "title": "📉 Mean ADX 趨勢",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"mean_adx\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "bars", "barAlignment": 0 },
          "decimals": 0,
          "min": -0.2, "max": 1.5,
          "mappings": [{ "options": { "0": { "text": "NO TRADE" }, "1": { "text": "TRADE OK" } }, "type": "value" }]
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 37 },
      "id": 13,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "right" }
