{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "description": "Algo Trading Monitor v3",
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "💰 Account",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 500 }, { "color": "green", "value": 700 }] },
          "unit": "currencyUSD", "decimals": 2
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "💰 Balance",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"account_balance\")\n  |> filter(fn: (r) => r._field == \"balance\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 500 }, { "color": "green", "value": 700 }] },
          "unit": "currencyUSD", "decimals": 2
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "📈 Equity",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"account_balance\")\n  |> filter(fn: (r) => r._field == \"equity\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 10 }] },
          "unit": "currencyUSD", "decimals": 2
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "💹 Total PnL",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"account_balance\")\n  |> filter(fn: (r) => r._field == \"total_pnl\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "options": {
            "-3": { "text": "🐻 熊市空頭", "color": "dark-red" },
            "-2": { "text": "📉 趨勢空頭", "color": "orange" },
            "-1": { "text": "⚪ MR空頭(停用)", "color": "gray" },
            "0":  { "text": "🔴 無信號", "color": "red" },
            "1":  { "text": "⚪ MR多頭(停用)", "color": "gray" },
            "2":  { "text": "📈 趨勢多頭", "color": "green" }
          }, "type": "value" }]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "🚦 Regime Signal",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"regime_signal\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "currencyUSD", "decimals": 2, "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "💰 Balance & Equity 曲線",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"account_balance\")\n  |> filter(fn: (r) => r._field == \"balance\" or r._field == \"equity\" or r._field == \"total_pnl\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "📊 Market Regime — 狀態",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.4 }, { "color": "green", "value": 0.6 }] },
          "unit": "percentunit", "decimals": 2, "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "📊 Composite Score",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"market_score\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 20 }, { "color": "green", "value": 25 }] },
          "decimals": 1
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "📉 Mean ADX",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"mean_adx\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "mappings": [{ "options": { "0": { "text": "✅ 正常", "color": "green" }, "1": { "text": "⛔ 剎車", "color": "red" } }, "type": "value" }]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "⛔ Brake 狀態",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"market_regime\")\n  |> filter(fn: (r) => r._field == \"brake\")\n  |> filter(fn: (r) => r.mode == \"LIVE\")\n  |> last()", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] },
          "mappings": [{ "options": { "0": { "text": "✅ 正常", "color": "green" }, "1": { "text": "🟡 軟剎車", "color": "orange" } }, "type": "value" }]
        }
